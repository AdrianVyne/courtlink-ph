{
  "name": "@courtlink/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require(\u0027node:fs\u0027).rmSync(\u0027dist\u0027,{recursive:true,force:true})\" \u0026\u0026 tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "biome lint src",
    "start": "node dist/main.js",
    "test": "vitest run src",
    "test:integration": "vitest run integration",
    "test:coverage": "vitest run src --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@courtlink/database": "workspace:*",
    "@courtlink/domain": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "bullmq": "5.79.1",
    "ioredis": "5.11.1",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.10.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
