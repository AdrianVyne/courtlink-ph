{
  "name": "@courtlink/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "biome lint src",
    "start": "node dist/main.js",
    "test": "vitest run src",
    "test:integration": "vitest run --passWithNoTests",
    "test:coverage": "vitest run src --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@courtlink/domain": "workspace:*",
    "bullmq": "5.66.4",
    "ioredis": "5.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
