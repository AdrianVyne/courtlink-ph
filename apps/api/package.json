{
  "name": "@courtlink/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "lint": "biome lint src",
    "start": "node dist/main.js",
    "test": "vitest run src",
    "test:integration": "vitest run integration",
    "test:coverage": "vitest run src --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.726.1",
    "@aws-sdk/s3-request-presigner": "3.726.1",
    "@courtlink/database": "workspace:*",
    "@courtlink/domain": "workspace:*",
    "@fastify/multipart": "9.2.1",
    "@fastify/static": "9.1.3",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@nestjs/swagger": "11.2.6",
    "@prisma/adapter-pg": "7.8.0",
    "argon2": "0.44.0",
    "bullmq": "5.66.4",
    "fastify": "5.7.0",
    "google-auth-library": "10.7.0",
    "ioredis": "5.8.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@nestjs/cli": "11.0.16",
    "@nestjs/testing": "11.1.27",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
