NODE_ENV=development
WEB_PORT=3000
API_PORT=3001
DATABASE_URL=postgresql://courtlink:courtlink@localhost:5433/courtlink?schema=public
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-at-least-32-random-bytes
ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@example.com
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=courtlink-private
OBJECT_STORAGE_ACCESS_KEY=courtlink
OBJECT_STORAGE_SECRET_KEY=replace-for-local-development
# Set to false only for true AWS S3; MinIO and OCI S3-compat need path-style (default true)
OBJECT_STORAGE_FORCE_PATH_STYLE=true
# Encrypted backups (compose.prod.yaml ackup profile)
BACKUP_ENCRYPTION_KEY=replace-with-at-least-16-random-bytes
# Optional separate bucket for backups; defaults to OBJECT_STORAGE_BUCKET
BACKUP_BUCKET=

# --- Production (compose.prod.yaml) ---
# Postgres runs inside the compose network; point DATABASE_URL at the service host.
POSTGRES_DB=courtlink
POSTGRES_USER=courtlink
POSTGRES_PASSWORD=replace-with-a-strong-db-password
# Use the in-network hostnames for the production stack:
#   DATABASE_URL=postgresql://courtlink:STRONG_PASSWORD@postgres:5432/courtlink?schema=public
#   REDIS_URL=redis://redis:6379
# SITE_ADDRESS is ":80" for local prod testing or your public hostname for TLS:
#   SITE_ADDRESS=courtlink-ph.duckdns.org
SITE_ADDRESS=:80



