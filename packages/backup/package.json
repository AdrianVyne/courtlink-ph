{
  "name": "@courtlink/backup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "courtlink-backup": "./bin/backup.mjs",
    "courtlink-restore": "./bin/restore.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome lint src",
    "test": "vitest run src",
    "test:integration": "vitest run --passWithNoTests",
    "test:coverage": "vitest run src --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1073.0",
    "@aws-sdk/lib-storage": "3.1073.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.10.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
