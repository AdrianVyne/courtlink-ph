{
  "name": "@courtlink/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./generated/client/client.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "prisma generate \u0026\u0026 tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:validate": "prisma validate",
    "lint": "biome lint prisma.config.ts",
    "test": "vitest run unit --passWithNoTests",
    "test:integration": "vitest run integration",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "prisma generate \u0026\u0026 tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "7.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@prisma/adapter-pg": "7.8.0",
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "argon2": "0.44.0",
    "dotenv": "17.2.3",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
